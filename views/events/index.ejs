<%- include("../partials/head") %>
  <%- include("../partials/navbar") %>
  <%- include("../partials/message") %>


    <header class="page-header">
      <div class="container">
        <span class="eyebrow">Find your next experience</span>
        <h1>Browse RP events</h1>
        <p class="text-body-secondary">
          Search by keyword, filter by school or category and sort the results.
        </p>
      </div>
    </header>

    <main class="container pb-5">
      <form action="/events" method="GET" class="event-filter-panel">
        <div class="row g-3 align-items-end">
          <div class="col-lg-4">
            <label for="search" class="form-label">Search</label>
            <div class="input-group input-group-lg">
              <span class="input-group-text">
                <i class="bi bi-search"></i>
              </span>
              <input id="search" name="search" type="search" class="form-control" placeholder="Title, venue or keyword"
                value="<%= filters.search %>">
            </div>
          </div>

          <div class="col-md-4 col-lg-3">
            <label for="school" class="form-label">School</label>
            <select id="school" name="school" class="form-select form-select-lg">
              <option value="">All RP schools</option>
              <% schools.forEach((school)=> { %>
                <option value="<%= school.code %>" <%=filters.school===school.code ? "selected" : "" %>
                  >
                  <%= school.code %>
                </option>
                <% }) %>
            </select>
          </div>

          <div class="col-md-4 col-lg-2">
            <label for="category" class="form-label">Category</label>
            <select id="category" name="category" class="form-select form-select-lg">
              <option value="">All categories</option>
              <% categories.forEach((category)=> { %>
                <option value="<%= category %>" <%=filters.category===category ? "selected" : "" %>
                  >
                  <%= category %>
                </option>
                <% }) %>
            </select>
          </div>

          <div class="col-md-4 col-lg-2">
            <label for="sort" class="form-label">Sort by</label>
            <select id="sort" name="sort" class="form-select form-select-lg">
              <option value="date-asc" <%=filters.sort==="date-asc" ? "selected" : "" %>
                >
                Soonest
              </option>
              <option value="date-desc" <%=filters.sort==="date-desc" ? "selected" : "" %>
                >
                Latest
              </option>
              <option value="title-asc" <%=filters.sort==="title-asc" ? "selected" : "" %>
                >
                Name A–Z
              </option>
              <option value="vacancies-desc" <%=filters.sort==="vacancies-desc" ? "selected" : "" %>
                >
                Most vacancies
              </option>
            </select>
          </div>

          <div class="col-lg-1">
            <button class="btn btn-vybe btn-lg w-100" type="submit">
              <i class="bi bi-sliders"></i>
            </button>
          </div>
        </div>

        <% if (filters.search || filters.school || filters.category) { %>
          <div class="mt-3">
            <a href="/events" class="clear-filter-link">
              <i class="bi bi-x-circle"></i>
              Clear filters
            </a>
          </div>
          <% } %>
      </form>

      <div class="results-heading">
        <div>
          <strong>
            <%= events.length %>
          </strong>
          <span>
            <%= events.length===1 ? "event found" : "events found" %>
          </span>
        </div>
      </div>

      <% if (events.length> 0) { %>
        <div class="row g-4">
          <% events.forEach((event)=> { %>
            <div class="col-md-6 col-xl-4">
              <article class="event-card h-100">
                <div class="event-card-banner school-<%= event.school.toLowerCase() %>">
                  <span class="event-school">
                    <%= event.school %>
                  </span>
                  <% if (event.posterImage) { %>
                    <img src="<%= event.posterImage %>" alt="<%= event.title %>"
                         style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;">
                  <% } else { %>
                    <i class="bi <%= event.icon %>"></i>
                  <% } %>
                </div>

                <div class="event-card-body">
                  <div class="d-flex justify-content-between align-items-center">
                    <span class="event-category">
                      <%= event.category %>
                    </span>
                    <span class="vacancy-pill">
                      <%= event.vacancies %> spots
                    </span>
                  </div>

                  <h3>
                    <%= event.title %>
                  </h3>
                  <p>
                    <%= event.description %>
                  </p>

                  <div class="event-meta">
                    <span>
                      <i class="bi bi-calendar3"></i>
                      <%= event.displayDate %> · <%= event.time %>
                    </span>
                    <span>
                      <i class="bi bi-geo-alt"></i>
                      <%= event.venue %>
                    </span>
                  </div>

                  <a href="/events/<%= event.id %>" class="btn btn-soft w-100">
                    View details
                  </a>
                  <!-- JOIN, CANCEL, AND SAVE BUTTONS- Uzair Shah -->
                  
                  <div class="d-flex flex-column gap-2 mt-3">

                    <!-- 1. JOIN EVENT BUTTON -->
                    <!-- Full events still get a working button - it joins
                         the waitlist instead of a confirmed spot (Edrik's
                         waitlist feature, in routes/bookmarks.js) -->
                    <% if (event.vacancies > 0) { %>
                      <form action="/events/<%= event.id %>/join" method="POST" class="w-100">
                        <button type="submit" class="btn btn-vybe w-100">
                          <i class="bi bi-person-plus-fill me-1"></i> Join Event
                        </button>
                      </form>
                      <% } else { %>
                        <form action="/events/<%= event.id %>/join" method="POST" class="w-100">
                          <button type="submit" class="btn btn-outline-secondary w-100">
                            <i class="bi bi-hourglass-split me-1"></i> Join Waitlist
                          </button>
                        </form>
                        <% } %>

                          <!-- 2. CANCEL & SAVE BUTTONS -->
                          <div class="d-flex gap-2">
                            <form action="/events/<%= event.id %>/cancel" method="POST" class="w-100">
                              <button type="submit" class="btn btn-outline-danger w-100 btn-sm">
                                Cancel
                              </button>
                            </form>

                            <form action="/events/<%= event.id %>/bookmark" method="POST" class="w-100">
                              <button type="submit" class="btn btn-outline-warning w-100 btn-sm">
                                <i class="bi bi-bookmark-star me-1"></i> Save
                              </button>
                            </form>
                          </div>

                  </div>
                  <!-- End - Uzair Shah -->
                </div>
              </article>
            </div>
            <% }) %>
        </div>
        <% } else { %>
          <section class="empty-results">
            <div class="empty-icon">
              <i class="bi bi-calendar-x"></i>
            </div>
            <h2>No events match your search</h2>
            <p class="text-body-secondary">
              Try using a different keyword or removing one of the filters.
            </p>
            <a href="/events" class="btn btn-vybe">Reset search</a>
          </section>
          <% } %>
    </main>

    <%- include("../partials/footer") %>