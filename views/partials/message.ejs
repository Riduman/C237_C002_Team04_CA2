<% if (message) { %>
  <div class="container pt-3">
    <div
      class="alert alert-<%= message.type %> alert-dismissible fade show rounded-4 border-0"
      role="alert"
    >
      <%= message.text %>
      <button
        type="button"
        class="btn-close"
        data-bs-dismiss="alert"
        aria-label="Close"
      ></button>
    </div>
  </div>
<% } %>
