<%- include("partials/head") %><%- include("partials/navbar") %>
<%- include("partials/message") %>
<section class="home-welcome" id="welcomeHero"><div class="confetti c1"></div><div class="confetti c2"></div><div class="confetti c3"></div><div class="container text-center welcome-content"><span>YOUR CAMPUS EVENT SPACE</span><h1>Welcome, <%= user.fullName %></h1><p>Discover something new, connect with your campus and make every school day more memorable.</p><div class="hero-actions"><a href="/events" class="btn btn-auth btn-lg">Explore Events</a><a href="/settings" class="btn btn-light btn-lg">Personalise Profile</a></div></div></section>
<section class="container-fluid px-lg-5 home-content"><div class="row g-4"><% [['🎟️','Discover Events','Find workshops, sports, charity events, seminars and celebrations.','pink'],['🔍','Search Your Way','Filter by RP school, category or keyword and sort the results.','blue'],['🌟','Make It Yours','Update your profile picture, details and preferred theme.','green']].forEach(x=>{ %><div class="col-lg-4"><article class="feature-panel <%= x[3] %>"><div class="feature-emoji"><%= x[0] %></div><span>VYBE FEATURE</span><h2><%= x[1] %></h2><p><%= x[2] %></p><a href="<%= x[1]==='Make It Yours'?'/settings':'/events' %>">Open feature <i class="bi bi-arrow-right"></i></a></article></div><% }) %></div><div class="section-heading mt-5"><div><span class="eyebrow">HAPPENING SOON</span><h2>Featured Events</h2></div><a href="/events">View all</a></div><div class="row g-4"><% featuredEvents.forEach(event=>{ %><div class="col-md-6 col-lg-4"><article class="event-card h-100"><div class="event-card-banner school-<%= event.school.toLowerCase() %>"><span class="event-school"><%= event.school %></span><i class="bi <%= event.icon %>"></i></div><div class="event-card-body"><div class="event-category"><%= event.category %></div><h3><%= event.title %></h3><p><%= event.description %></p><div class="event-meta"><span><i class="bi bi-calendar3"></i><%= event.displayDate %></span><span><i class="bi bi-geo-alt"></i><%= event.venue %></span></div><a href="/events/<%= event.id %>" class="btn btn-soft w-100">View Event</a></div></article></div><% }) %></div></section><script src="/js/home-scroll.js"></script><%- include("partials/footer") %>