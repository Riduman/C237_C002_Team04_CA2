<%- include("partials/head") %>
<%- include("partials/navbar") %>
<%- include("partials/message") %>

<header class="page-header">
  <div class="container">
    <span class="eyebrow">Saved for later</span>
    <h1>My Bookmarks</h1>
    <p class="text-body-secondary">Events you've saved to join later.</p>
  </div>
</header>

<main class="container pb-5">
  <% if (events.length === 0) { %>
    <section class="empty-results">
      <div class="empty-icon">
        <i class="bi bi-bookmark-heart"></i>
      </div>
      <h2>No bookmarks yet</h2>
      <p class="text-body-secondary">
        Browse events and tap "Save" on anything you'd like to join later.
      </p>
      <a href="/events" class="btn btn-vybe">Browse Events</a>
    </section>
  <% } else { %>
    <div class="row g-4">
      <% events.forEach((event) => { %>
        <div class="col-md-6 col-xl-4">
          <article class="event-card h-100">
            <div class="event-card-banner school-<%= event.school.toLowerCase() %>">
              <span class="event-school"><%= event.school %></span>
              <% if (event.posterImage) { %>
                <img src="<%= event.posterImage %>" alt="<%= event.title %>"
                     style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;">
              <% } else { %>
                <i class="bi <%= event.icon %>"></i>
              <% } %>
            </div>

            <div class="event-card-body">
              <div class="d-flex justify-content-between align-items-center">
                <span class="event-category"><%= event.category %></span>
                <span class="vacancy-pill"><%= event.vacancies %> spots</span>
              </div>

              <h3><%= event.title %></h3>
              <p><%= event.description %></p>

              <div class="event-meta">
                <span><i class="bi bi-calendar3"></i> <%= event.displayDate %> · <%= event.time %></span>
                <span><i class="bi bi-geo-alt"></i> <%= event.venue %></span>
              </div>

              <div class="d-flex flex-column gap-2 mt-3">
                <a href="/events/<%= event.id %>" class="btn btn-soft w-100">View details</a>

                <% if (event.vacancies > 0) { %>
                  <form action="/events/<%= event.id %>/join" method="POST">
                    <button type="submit" class="btn btn-vybe w-100">
                      <i class="bi bi-person-plus-fill me-1"></i> Join Event
                    </button>
                  </form>
                <% } else { %>
                  <form action="/events/<%= event.id %>/join" method="POST">
                    <button type="submit" class="btn btn-outline-secondary w-100">
                      <i class="bi bi-hourglass-split me-1"></i> Join Waitlist
                    </button>
                  </form>
                <% } %>

                <form action="/events/<%= event.id %>/unbookmark" method="POST">
                  <button type="submit" class="btn btn-outline-warning w-100 btn-sm">
                    <i class="bi bi-bookmark-x me-1"></i> Remove Bookmark
                  </button>
                </form>
              </div>
            </div>
          </article>
        </div>
      <% }) %>
    </div>
  <% } %>
</main>

<%- include("partials/footer") %>
